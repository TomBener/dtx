{
  "name": "dtx",
  "version": "0.9.0",
  "description": "Non-interactive dtx CLI for DEVONthink indexing and semantic retrieval",
  "repository": {
    "type": "git",
    "url": "https://github.com/TomBener/dt-agent-cli.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "dtx": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "check": "tsc --noEmit && eslint src/ && prettier --check src/",
    "update": "git pull origin main && npm install && npm run build"
  },
  "keywords": [
    "devonthink",
    "cli",
    "jxa",
    "semantic-search",
    "rag"
  ],
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "openai": "^6.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.2.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0"
  }
}
